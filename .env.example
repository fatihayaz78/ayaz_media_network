# Ayaz Media Network — Environment Variables
# Copy to .env and fill in your keys

# AI channels (techai, news, transfer rumours)
ANTHROPIC_API_KEY=your_key_here

# Sports fixtures (SportAPI7 via RapidAPI)
RAPIDAPI_KEY=your_key_here

# Football transfer data (optional)
FOOTBALL_DATA_KEY=your_key_here

# Esports (PandaScore) — optional
PANDASCORE_KEY=your_key_here

# Game releases (RAWG) — optional
RAWG_KEY=your_key_here
